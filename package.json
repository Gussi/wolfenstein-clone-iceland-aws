{
  "name": "pots-and-parliament",
  "version": "0.1.0",
  "description": "A Wolfenstein 3D style raycaster satirizing Icelandic institutional dysfunction. Nonlethal slapstick combat with kitchenware.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "level:generate": "node tools/generate-level.mjs",
    "level:verify": "node tools/verify-level.mjs"
  },
  "keywords": [
    "game",
    "raycaster",
    "wolfenstein",
    "typescript",
    "satire"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "fast-check": "^3.0.0"
  }
}
